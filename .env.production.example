# Copy values into the service account environment. Do not commit real secrets.
AGENT_COMPANY_REPO=D:\absolute\path\to\managed-repository
AGENT_COMPANY_CHECK_FILE=D:\absolute\path\to\managed-repository\scripts\check.js
AGENT_COMPANY_RUNTIME=D:\agent-company-runtime
AGENT_COMPANY_GIT=C:\Program Files\Git\cmd\git.exe
AGENT_COMPANY_API_TOKEN=replace-with-at-least-16-random-characters
AGENT_COMPANY_REDIS_HOST=127.0.0.1
AGENT_COMPANY_REDIS_PORT=6379
PORT=4310

# standalone | openai-compatible | legacy-nvidia | claude-cli | codex-cli
AGENT_COMPANY_HOST=standalone
AGENT_COMPANY_MODEL=phase0-model
AGENT_COMPANY_MODEL_MAX_TOKENS=8192
AGENT_COMPANY_ROLE_DEADLINE_MS=300000
# AGENT_COMPANY_MODEL_BASE_URL=http://127.0.0.1:11434/v1
# AGENT_COMPANY_MODEL_API_KEY=environment-only-secret
# AGENT_COMPANY_CLI_PATH=C:\absolute\path\to\codex.exe

# Build-stage owner review evidence. The preview must serve the exact Run build
# and expose meta[name="agent-company-build-version"] with the Run patch hash.
BROWSER_AUTOMATION_EXECUTABLE=C:\Program Files\Google\Chrome\Application\chrome.exe
# AGENT_COMPANY_REVIEW_PREVIEW_URL=https://preview.example.internal
# VITE_BUILD_VERSION=replace-with-run-patch-hash
